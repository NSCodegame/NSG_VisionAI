# NSG VisionAI Platform - Environment Configuration
# Copy this file to .env and update with your actual values

# ============================================================================
# APPLICATION SETTINGS
# ============================================================================
APP_NAME=NSG VisionAI Platform
APP_VERSION=0.1.0
ENVIRONMENT=development  # development, staging, production
DEBUG=true
LOG_LEVEL=INFO

# ============================================================================
# DATABASE SETTINGS (PostgreSQL + TimescaleDB + pgvector)
# ============================================================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=nsg_visionai
POSTGRES_USER=nsg_admin
POSTGRES_PASSWORD=change_me_in_production
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# ============================================================================
# REDIS SETTINGS (Celery broker and caching)
# ============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=change_me_in_production
REDIS_DB=0
REDIS_URL=redis://:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}/${REDIS_DB}

# ============================================================================
# CELERY SETTINGS
# ============================================================================
CELERY_BROKER_URL=${REDIS_URL}
CELERY_RESULT_BACKEND=${REDIS_URL}
CELERY_TASK_SERIALIZER=json
CELERY_RESULT_SERIALIZER=json
CELERY_ACCEPT_CONTENT=json
CELERY_TIMEZONE=Asia/Kolkata
CELERY_ENABLE_UTC=true

# ============================================================================
# MINIO SETTINGS (S3-compatible object storage)
# ============================================================================
MINIO_ENDPOINT=localhost:9000
MINIO_ROOT_USER=nsg_admin
MINIO_ROOT_PASSWORD=change_me_in_production
MINIO_ACCESS_KEY=${MINIO_ROOT_USER}
MINIO_SECRET_KEY=${MINIO_ROOT_PASSWORD}
MINIO_BUCKET_NAME=nsg-visionai
MINIO_SECURE=false  # Set to true in production with TLS
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# ============================================================================
# JWT AUTHENTICATION SETTINGS
# ============================================================================
# Generate RS256 keys: openssl genrsa -out private_key.pem 2048
#                      openssl rsa -in private_key.pem -pubout -out public_key.pem
JWT_ALGORITHM=RS256
JWT_ACCESS_TOKEN_EXPIRE_HOURS=8
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30
JWT_PRIVATE_KEY_PATH=./keys/private_key.pem
JWT_PUBLIC_KEY_PATH=./keys/public_key.pem

# ============================================================================
# ENCRYPTION SETTINGS (AES-256-GCM for video segments)
# ============================================================================
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
ENCRYPTION_MASTER_KEY=change_me_to_64_char_hex_string_in_production_00000000000000
VIDEO_ENCRYPTION_ALGORITHM=AES-256-GCM

# ============================================================================
# ML MODEL SETTINGS
# ============================================================================
# YOLOv8 Object Detection
YOLO_MODEL_PATH=./models/yolov8x.pt
YOLO_CONFIDENCE_THRESHOLD=0.75
YOLO_NMS_THRESHOLD=0.45
YOLO_INPUT_SIZE=640
YOLO_BATCH_SIZE=4

# RetinaFace Face Detection
RETINAFACE_MODEL_PATH=./models/retinaface_resnet50.pth
RETINAFACE_CONFIDENCE_THRESHOLD=0.90

# ArcFace Face Recognition
ARCFACE_MODEL_PATH=./models/arcface_resnet100.pth
ARCFACE_EMBEDDING_SIZE=512
FACE_MATCH_THRESHOLD=0.85

# ByteTrack Person Tracking
BYTETRACK_TRACK_BUFFER=30
BYTETRACK_MATCH_THRESHOLD=0.6
BYTETRACK_REID_THRESHOLD=0.85

# LSTM Anomaly Detection
LSTM_MODEL_PATH=./models/lstm_anomaly.pth
LSTM_SEQUENCE_LENGTH=30
LSTM_ANOMALY_THRESHOLD=0.70

# ============================================================================
# VIDEO STREAM SETTINGS
# ============================================================================
VIDEO_STREAM_FPS_AI=5  # Frame rate for AI processing
VIDEO_STREAM_FPS_DISPLAY=25  # Frame rate for display
VIDEO_STREAM_BUFFER_SIZE=100
VIDEO_STREAM_RECONNECT_ATTEMPTS=5
VIDEO_STREAM_RECONNECT_DELAY=5  # seconds
VIDEO_STREAM_CONNECTION_TIMEOUT=10  # seconds

# ============================================================================
# ALERT SETTINGS
# ============================================================================
ALERT_DEDUPLICATION_WINDOW=30  # seconds
ALERT_P1_AUTO_RESOLVE=false  # P1_CRITICAL alerts require manual resolution

# ============================================================================
# VIDEO ARCHIVAL SETTINGS
# ============================================================================
VIDEO_SEGMENT_DURATION=600  # 10 minutes in seconds
VIDEO_RETENTION_DAYS=30
VIDEO_FLAGGED_RETENTION_PERMANENT=true
VIDEO_CODEC=h264
VIDEO_COMPRESSION_QUALITY=23  # CRF value (lower = better quality)

# ============================================================================
# SECURITY SETTINGS
# ============================================================================
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
CORS_ALLOW_CREDENTIALS=true
RATE_LIMIT_LOGIN=10  # requests per minute
ACCOUNT_LOCKOUT_ATTEMPTS=5
ACCOUNT_LOCKOUT_DURATION=1800  # 30 minutes in seconds
PASSWORD_BCRYPT_ROUNDS=12

# ============================================================================
# MONITORING SETTINGS
# ============================================================================
FLOWER_PORT=5555
FLOWER_USER=admin
FLOWER_PASSWORD=change_me_in_production
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001

# ============================================================================
# GPU SETTINGS
# ============================================================================
CUDA_VISIBLE_DEVICES=0,1  # GPU device IDs
GPU_MEMORY_FRACTION=0.8  # Fraction of GPU memory to use per worker

# ============================================================================
# IP CAMERA SETTINGS
# ============================================================================
IP_CAMERA_DEFAULT_PORT=554           # Standard RTSP port
IP_CAMERA_DEFAULT_USERNAME=admin     # Most cameras default to 'admin'
IP_CAMERA_DEFAULT_PASSWORD=          # Leave blank — set per-camera via API
IP_CAMERA_ONVIF_PORT=80              # ONVIF discovery port
IP_CAMERA_DISCOVERY_TIMEOUT=3        # Seconds to wait per host during scan
IP_CAMERA_DISCOVERY_SUBNET=192.168.1.0/24  # Subnet to scan for cameras

# ============================================================================
# FRONTEND SETTINGS
# ============================================================================
VITE_API_BASE_URL=http://localhost:8000
VITE_WS_BASE_URL=ws://localhost:8000
